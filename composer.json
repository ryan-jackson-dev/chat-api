{
    "name": "ryan-jackson-dev/chat-api",
    "description": "Experimental chat REST API",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Ryan Jackson"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "_": "Using 8.3.6 since it is built into this distribution of Ubuntu.",
        "platform": {
            "php": "8.3.6"
        }
    },
    "require": {
        "php": "^8.3.6",
        "php-di/php-di": "^7.1",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "ramsey/uuid": "^4.9"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12"
    },
    "scripts": {
        "format": "php-cs-fixer fix",
        "init-db": "sqlite3 var/database.sqlite < database/schema.sql",
        "lint": "phpstan analyse",
        "serve": "php -S localhost:8080 -t public",
        "test": "phpunit --display-warnings tests/",
        "test-env": "php testEnv.php"
    }
}
